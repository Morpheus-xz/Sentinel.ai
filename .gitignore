# ==========================================
# SENTINEL.AI - Enterprise .gitignore
# ==========================================

# 1. AI Models & Heavy Weights (CRITICAL FOR GITHUB LIMITS)
*.onnx
*.bin
*.pt
*.pth
*.h5
# (Optional: If you want to ignore the whole models folder, uncomment the next line)
# backend/models/

# 2. OS Generated Files (Crucial for your Mac)
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 3. Python / FastAPI Backend
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/
.coverage

# 4. Node.js / React Frontend
node_modules/
dist/
dist-ssr/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 5. Environment Variables (SECURITY CRITICAL)
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# 6. IDE / Editor Folders
.vscode/
.idea/
*.swp
*.swo

# 7. Temporary & Uploaded Files
*.zip
*.tar.gz
*.rar
*.logbackend/models/
